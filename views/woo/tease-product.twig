<article {{ fn('post_class', ['$classes', 'entry', 'col-span-1', 'min-h-85', 'gap-4', 'flex', 'flex-col','justify-between', 'items-center'] ) }}>
	{{ fn('App\\timber_set_product', post) }}
	{% if post.thumbnail %}
		<div class="media-figure text-center {% if not post.thumbnail %}placeholder{% endif %}">
			<header>
				{% if post.thumbnail %}
					<div class="relative w-full h-60 block overflow-hidden bg-white mb-2">
						{% if fn('is_user_logged_in') %}
							{% set is_fav = fishingfanatic_is_favourite(post.ID) %}
							<button class="absolute top-0 right-0 fav-btn {% if is_fav %}active{% endif %}" data-product-id="{{ post.ID }}" aria-label="{% if is_fav %}Remove from favourites{% else %}Add to favourites{% endif %}">
								<svg xmlns="http://www.w3.org/2000/svg" viewbox="0 0 24 24" width="24" height="24">
									<path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09 C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5 c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
								</svg>
							</button>
						{% endif %}

						<img src="{{ post.thumbnail.src('medium') }}" class="w-full h-full object-cover"/>
					</div>
				{% else %}
					<span class="thumb-placeholder">
						<i class="icon-camera"></i>
					</span>
				{% endif %}
			</header>

			{% if post.title %}
				<h2 class="entry-title text-center mb-2">
					<a href="{{ post.link }}" class="uppercase font-medium text-black text-center hover:underline">{{ post.title }}</a>
				</h2>
			{% else %}
				<h2 class="entry-title text-center mb-2">
					<a href="{{ post.link }}" class="uppercase font-medium text-black text-center hover:underline">{{ fn('the_title') }}</a>
				</h2>
			{% endif %}

			{% do action( 'woocommerce_after_shop_loop_item_title' ) %}
		</div>
	{% endif %}

	<div class="media-content">
		{% do action( 'woocommerce_after_shop_loop_item' ) %}
	</div>
</article>
