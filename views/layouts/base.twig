<!DOCTYPE html>
<html {{ site.language_attributes }}>
	{% block head %}
		{% include 'header/head.twig' %}
	{% endblock %}

	<body class="{{ body_class }}">
		{{ function('wp_body_open') }}

		<a class="skip-to-content-link absolute w-[1px] h-[1px] top-auto overflow-hidden -z-[999] -left-[999px]" href="#content">{{ _e('Skip to content') }}</a>

		{% block header %}
			{% include 'header/index.twig' %}
		{% endblock %}

		<div id="main-wrapper" class="text-gray-800 py-8">
			<main id="main-content" role="main">
				<div class="content container bg-white">
					{% block content %}
						Sajnáljuk, ezen az oldalon nem található tartalom.
					{% endblock %}
				</div>
			</main>
		</div>

		{% block footer %}
			{% include 'footer/index.twig' %}
		{% endblock %}
		{{ function('wp_footer') }}
		{% do action('get_footer') %}
	</body>
</html>
